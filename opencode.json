{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "skills": {
    "paths": [".agents/skills"]
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:.secrets/github-token}"
      }
    },
    "angular-cli": {
      "type": "local",
      "command": ["npx", "-y", "@angular/cli@latest", "mcp"]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:.secrets/context7-key}"
      }
    }
  }
}
